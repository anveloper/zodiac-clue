# NPC 대사용 Gemini (선택). 없으면 규칙기반 폴백 대사로 동작.
# 무료티어 발급: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# 모델 (기본: gemini-flash-lite-latest = 저지연·무료 RPM 넉넉, 짧은 대사에 적합).
# flash 계열은 thinking 모델이라 서버가 thinkingBudget:0으로 끄고 호출한다(빈 응답 방지).
GEMINI_MODEL=gemini-flash-lite-latest

# 서버 포트 (기본 2567)
# PORT=2567
